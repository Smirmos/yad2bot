# ── Telegram (one bot per city, same personal chat ID) ──────────
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_TOKEN_RAMAT_GAN=
TELEGRAM_TOKEN_HERZLIYA=
TELEGRAM_TOKEN_RAANANA=
TELEGRAM_TOKEN_PETAH_TIKVA=
TELEGRAM_TOKEN_HOD_HASHARON=

# ── Zyte API (zyte.com) ─────────────────────────────────────────
ZYTE_API_KEY=your-zyte-api-key

# ── Redis (Railway auto-injects REDIS_URL) ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Search filters ──────────────────────────────────────────────
MAX_PRICE=9000
MIN_PRICE=0
ROOMS=3,3.5,4
CHECK_INTERVAL_MINUTES=300

# Boolean filters (1 = required, 0 = off)
FILTER_BALCONY=1
FILTER_PARKING=1
FILTER_ELEVATOR=1
FILTER_MAMAD=1
