TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Zyte API — required, for bypassing Yad2 anti-bot (zyte.com)
ZYTE_API_KEY=your-zyte-api-key

# ── Search criteria ──────────────────────────────────────────────
MAX_PRICE=9000
MIN_PRICE=0
ROOMS=3,3.5,4

# Cities — comma-separated Yad2 city IDs
# תל אביב = 5000 | רמת גן = 8600 | פתח תקווה = 7900
# רעננה = 8700    | הרצליה = 6400
CITIES=5000,8600,7900,8700,6400

# Area-based search (instead of or in addition to city IDs)
# For הוד השרון: AREA=54, TOP_AREA=19 (no city ID needed)
# Leave empty if using CITIES only.
AREA=
TOP_AREA=
REGION=

# ── Boolean filters (1 = required, 0 = off, default 0) ──────────
FILTER_BALCONY=0          # מרפסת — balcony
FILTER_PARKING=0          # חניה פרטית — private parking
FILTER_ELEVATOR=0         # מעלית — elevator
FILTER_MAMAD=0            # ממ"ד — safe room

# ── Bot settings ─────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15

# Redis — required for seen-listings deduplication
# Railway auto-injects REDIS_URL when you add the Redis plugin
REDIS_URL=redis://localhost:6379
