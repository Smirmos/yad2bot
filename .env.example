TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ScraperAPI — required, free tier at scraperapi.com (1000 req/month)
SCRAPER_API_KEY=your-scraper-api-key

# ── Search criteria ──────────────────────────────────────────────
MAX_PRICE=9000
MIN_PRICE=0
ROOMS=3,3.5,4
CITY_ID=5000

# Area & region — use Yad2 network tab to find IDs
# Example: AREA=1 for Tel Aviv area, REGION=3,5,7 for specific regions
# Leave empty to search the whole city.
AREA=
REGION=

# ── Boolean filters (1 = required, 0 = off, default 0) ──────────
FILTER_BALCONY=0          # מרפסת — balcony
FILTER_PARKING=0          # חניה פרטית — private parking
FILTER_ELEVATOR=0         # מעלית — elevator
FILTER_MAMAD=0            # ממ"ד — safe room

# ── Bot settings ─────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15

# Redis — required for seen-listings deduplication
# Railway auto-injects REDIS_URL when you add the Redis plugin
REDIS_URL=redis://localhost:6379
